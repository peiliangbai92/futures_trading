//@version=6
// =============================================================================
// GC Multi-Timeframe RSI Mean-Reversion Strategy
// -----------------------------------------------------------------------------
// Buy oversold gold when a ladder of timeframes agree, OR when a fast-timeframe
// bullish RSI divergence prints while the higher timeframes are still soft — and
// only when short-term momentum has turned up. Exit on an ATR stop or when the
// fast RSIs flip overbought.
//
// Timeframes: 1m / 5m / 10m / 30m / 1h / 4h  (pulled via request.security, so the
// script can be attached to any chart timeframe — 5m is the intended base).
//
// RSI is computed with SMA smoothing of gains/losses (length 14), per the design
// spec — this is NOT the built-in ta.rsi() (which uses Wilder's RMA). The two
// differ slightly; that is intentional.
//
// Non-repainting: higher-timeframe values use lookahead_off and (when noRepaint
// is on) reference the last CLOSED HTF bar; strategy actions fire only on
// confirmed chart bars.
// =============================================================================

strategy("GC MTF RSI (SMA)", overlay=true, pyramiding=0,
     calc_on_every_tick=false, process_orders_on_close=true,
     initial_capital=50000, default_qty_type=strategy.fixed, default_qty_value=1,
     max_labels_count=200)

// ---------------------------------------------------------------- inputs: RSI
grpR = "RSI (SMA-smoothed, per design)"
rsiLen = input.int(14, "RSI length", minval=2, group=grpR)

// ----------------------------------------------- inputs: Gate A oversold ladder
grpA = "Gate A — oversold entry (tick the TFs to require)"
// Tick a timeframe to require it to be oversold for entry; unticked = ignored.
// Entry (Gate A) fires when EVERY ticked timeframe is oversold.
useA1   = input.bool(true,  "1m",  inline="eA1",   group=grpA)
th1     = input.int(30, "RSI <=", inline="eA1",   minval=1, maxval=99, group=grpA)
useA5   = input.bool(true,  "5m",  inline="eA5",   group=grpA)
th5     = input.int(30, "RSI <=", inline="eA5",   minval=1, maxval=99, group=grpA)
useA10  = input.bool(true,  "10m", inline="eA10",  group=grpA)
th10    = input.int(30, "RSI <=", inline="eA10",  minval=1, maxval=99, group=grpA)
useA30  = input.bool(true,  "30m", inline="eA30",  group=grpA)
th30    = input.int(35, "RSI <=", inline="eA30",  minval=1, maxval=99, group=grpA)
useA60  = input.bool(true,  "1h",  inline="eA60",  group=grpA)
th60    = input.int(37, "RSI <=", inline="eA60",  minval=1, maxval=99, group=grpA)
useA240 = input.bool(true,  "4h",  inline="eA240", group=grpA)
th240   = input.int(40, "RSI <=", inline="eA240", minval=1, maxval=99, group=grpA)

// ----------------------------------------------------- inputs: Gate B divergence
grpB = "Gate B — bullish RSI divergence"
useDivGate = input.bool(true,  "Enable divergence entry (Gate B)", group=grpB)
divRsi60  = input.int(40, "1h RSI <  (div context)", minval=1, maxval=99, group=grpB)
divRsi240 = input.int(40, "4h RSI <  (div context)", minval=1, maxval=99, group=grpB)
pivLbL = input.int(5,  "Pivot left bars",  minval=1, group=grpB)
pivLbR = input.int(5,  "Pivot right bars", minval=1, group=grpB)
rngMin = input.int(5,  "Min bars between pivots", minval=1, group=grpB)
rngMax = input.int(60, "Max bars between pivots", minval=2, group=grpB)
divHold = input.int(3, "Bars a divergence stays 'active'", minval=0, group=grpB)

// ----------------------------------------------------------- inputs: momentum
grpM = "Momentum gate (ROC)"
useMomentum = input.bool(true, "Require momentum gate", group=grpM)
momLen   = input.int(10, "Momentum (ROC) length", minval=1, group=grpM)
momThr   = input.float(0.0, "Fast TF 'significant positive' >", step=0.05, group=grpM)
momFloor = input.float(0.0, "Slow TF 'not negative' >=",       step=0.05, group=grpM)

// -------------------------------------------------------------- inputs: exit
grpE = "Exit — ATR stop + take-profit"
atrLen  = input.int(14, "ATR length", minval=1, group=grpE)
atrMult = input.float(2.0, "ATR stop multiple (loss)", minval=0.1, step=0.1, group=grpE)
tpMult  = input.float(3.0, "ATR take-profit multiple (gain)", minval=0.1, step=0.1, group=grpE)
useObExit = input.bool(true, "Enable RSI-overbought exit", group=grpE)
// Tick a timeframe to require it to be overbought for this exit; unticked =
// ignored. The overbought exit fires when EVERY ticked timeframe is overbought.
useX1   = input.bool(true,  "1m",  inline="xX1",   group=grpE)
exTh1   = input.int(70, "RSI >=", inline="xX1",   minval=1, maxval=99, group=grpE)
useX5   = input.bool(true,  "5m",  inline="xX5",   group=grpE)
exTh5   = input.int(70, "RSI >=", inline="xX5",   minval=1, maxval=99, group=grpE)
useX10  = input.bool(true,  "10m", inline="xX10",  group=grpE)
exTh10  = input.int(70, "RSI >=", inline="xX10",  minval=1, maxval=99, group=grpE)
useX30  = input.bool(true,  "30m", inline="xX30",  group=grpE)
exTh30  = input.int(65, "RSI >=", inline="xX30",  minval=1, maxval=99, group=grpE)
useX60  = input.bool(true,  "1h",  inline="xX60",  group=grpE)
exTh60  = input.int(63, "RSI >=", inline="xX60",  minval=1, maxval=99, group=grpE)
useX240 = input.bool(true,  "4h",  inline="xX240", group=grpE)
exTh240 = input.int(60, "RSI >=", inline="xX240", minval=1, maxval=99, group=grpE)

// ----------------------------------------------------------- inputs: execution
grpX = "Execution"
qty = input.int(1, "Contracts per entry", minval=1, group=grpX)
useShort = input.bool(true, "Enable short entries (short when overbought & flat)", group=grpX)
noRepaint = input.bool(true, "Non-repainting HTF (use last closed bar)", group=grpX)
showTable = input.bool(true, "Show status table", group=grpX)

// ------------------------------------------------------------ inputs: trend filter
grpF = "Trend filter — avoid counter-trend entries"
useTrend = input.bool(true, "Enable trend filter", group=grpF)
trendTf  = input.timeframe("240", "Trend timeframe", group=grpF)
trendLen = input.int(50, "Trend EMA length", minval=1, group=grpF)

// -------------------------------------------------- inputs: trailing / breakeven
grpT = "Trailing / breakeven — initial stop stays fixed, only moves in your favour"
useBE     = input.bool(true,  "Move stop to breakeven", group=grpT)
beTrig    = input.float(1.0,  "Breakeven trigger (ATR in profit)", minval=0.1, step=0.1, group=grpT)
useTrail  = input.bool(true,  "Trail stop by ATR", group=grpT)
trailMult = input.float(2.0,  "Trailing distance (ATR)", minval=0.1, step=0.1, group=grpT)

// Per-timeframe non-repaint offset. A timeframe HIGHER than the chart would
// repaint if we read its live (unclosed) bar, so those use 1 = last CLOSED bar.
// The chart timeframe and anything lower use 0 = the current bar, so the base
// signal fires on the very bar that triggers it (no spurious 1-bar lag).
// noRepaint off => 0 everywhere = fully immediate, but higher TFs then repaint.
chartSec = timeframe.in_seconds(timeframe.period)
f_off(tf) => (noRepaint and timeframe.in_seconds(tf) > chartSec) ? 1 : 0

// ---------------------------------------------------------------- functions
// RSI with SMA smoothing of up/down moves (design spec: "SMA, length 14").
f_rsi_sma(src, len) =>
    ch = ta.change(src)
    up = ta.sma(math.max(ch, 0.0), len)
    dn = ta.sma(-math.min(ch, 0.0), len)
    dn == 0.0 ? 100.0 : up == 0.0 ? 0.0 : 100.0 - 100.0 / (1.0 + up / dn)

// Regular bullish divergence on the RSI: price makes a lower low while the RSI
// makes a higher low, measured between two confirmed RSI pivot lows. Causal —
// a pivot at bar p is only known pivLbR bars later, and we reference it then.
// Returns true for `divHold` bars after each confirmation. Reads the config
// inputs directly (keeps ta.pivotlow's length args 'simple').
f_bull_div() =>
    r  = f_rsi_sma(close, rsiLen)
    pv = ta.pivotlow(r, pivLbL, pivLbR)    // RSI value at the pivot, else na
    var float pRsi = na
    var float pLow = na
    var int   pBar = na
    ev = false
    if not na(pv)
        curBar = bar_index - pivLbR
        curLow = low[pivLbR]
        if not na(pRsi)
            gap = curBar - pBar
            ev := gap >= rngMin and gap <= rngMax and pv > pRsi and curLow < pLow
        pRsi := pv
        pLow := curLow
        pBar := curBar
    bs = ta.barssince(ev)
    (not na(bs)) and (bs <= divHold)

// Per-timeframe state bundle, computed IN the requested timeframe's context and
// offset by repN bars for non-repainting (repN comes from f_off per TF).
f_state(repN) =>
    r = f_rsi_sma(close, rsiLen)
    m = ta.roc(close, momLen)
    d = f_bull_div()
    [r[repN], m[repN], d[repN]]

[rsi1s,   _mom1,  _div1]  = request.security(syminfo.tickerid, "1",   f_state(f_off("1")),   lookahead=barmerge.lookahead_off)
[rsi5s,   mom5s,  div5s]  = request.security(syminfo.tickerid, "5",   f_state(f_off("5")),   lookahead=barmerge.lookahead_off)
[rsi10s,  mom10s, div10s] = request.security(syminfo.tickerid, "10",  f_state(f_off("10")),  lookahead=barmerge.lookahead_off)
[rsi30s,  mom30s, div30s] = request.security(syminfo.tickerid, "30",  f_state(f_off("30")),  lookahead=barmerge.lookahead_off)
[rsi60s,  mom60s, _d60]   = request.security(syminfo.tickerid, "60",  f_state(f_off("60")),  lookahead=barmerge.lookahead_off)
[rsi240s, mom240s,_d240]  = request.security(syminfo.tickerid, "240", f_state(f_off("240")), lookahead=barmerge.lookahead_off)

// Zero-lag override: whichever slot equals the CHART timeframe is computed
// natively on the chart (no request.security, so no 1-bar security lag) — the
// base signal is then evaluated on the very bar it happens. Other TFs keep the
// non-repainting request.security value.
rsiC = f_rsi_sma(close, rsiLen)
momC = ta.roc(close, momLen)
divC = f_bull_div()
isC(tf) => timeframe.in_seconds(tf) == chartSec

rsi1   = isC("1")   ? rsiC : rsi1s
rsi5   = isC("5")   ? rsiC : rsi5s
mom5   = isC("5")   ? momC : mom5s
div5   = isC("5")   ? divC : div5s
rsi10  = isC("10")  ? rsiC : rsi10s
mom10  = isC("10")  ? momC : mom10s
div10  = isC("10")  ? divC : div10s
rsi30  = isC("30")  ? rsiC : rsi30s
mom30  = isC("30")  ? momC : mom30s
div30  = isC("30")  ? divC : div30s
rsi60  = isC("60")  ? rsiC : rsi60s
mom60  = isC("60")  ? momC : mom60s
rsi240 = isC("240") ? rsiC : rsi240s
mom240 = isC("240") ? momC : mom240s

// Higher-timeframe trend (EMA + slope) for the counter-trend filter.
f_trend(repN) =>
    e  = ta.ema(close, trendLen)
    sl = e - e[1]
    [e[repN], sl[repN]]
[trendEma, trendSlope] = request.security(syminfo.tickerid, trendTf, f_trend(f_off(trendTf)), lookahead=barmerge.lookahead_off)

// Confirmed trend = price on the trend side of the EMA AND the EMA sloping that way.
trendUp = close > trendEma and trendSlope > 0
trendDn = close < trendEma and trendSlope < 0
longOk  = (not useTrend) or (not trendDn)   // don't buy dips in a confirmed downtrend
shortOk = (not useTrend) or (not trendUp)   // don't sell rips in a confirmed uptrend

// ---------------------------------------------------------------- signal logic
// Gate A — every TICKED timeframe must be oversold (unticked ones are ignored).
a1ok   = not useA1   or rsi1   <= th1
a5ok   = not useA5   or rsi5   <= th5
a10ok  = not useA10  or rsi10  <= th10
a30ok  = not useA30  or rsi30  <= th30
a60ok  = not useA60  or rsi60  <= th60
a240ok = not useA240 or rsi240 <= th240
anySelA = useA1 or useA5 or useA10 or useA30 or useA60 or useA240
gateA = anySelA and a1ok and a5ok and a10ok and a30ok and a60ok and a240ok

// Gate B — a fast-TF bullish divergence (5m/10m/30m per design) while the slow
// TFs are still soft.
gateB = useDivGate and (div5 or div10 or div30) and rsi60 < divRsi60 and rsi240 < divRsi240

// Momentum gate — fast TFs turning up, slow TFs not falling.
momGate = (not useMomentum) or (mom5 > momThr and mom10 > momThr and mom30 > momThr and mom60 >= momFloor and mom240 >= momFloor)

entryLong = (gateA or gateB) and momGate and longOk

// Exit conditions
atrVal = ta.atr(atrLen)
// Exit-side overbought — every TICKED timeframe must be overbought (mirror of
// Gate A on the entry side; unticked TFs are ignored).
x1ok   = not useX1   or rsi1   >= exTh1
x5ok   = not useX5   or rsi5   >= exTh5
x10ok  = not useX10  or rsi10  >= exTh10
x30ok  = not useX30  or rsi30  >= exTh30
x60ok  = not useX60  or rsi60  >= exTh60
x240ok = not useX240 or rsi240 >= exTh240
anySelX = useX1 or useX5 or useX10 or useX30 or useX60 or useX240
overbought = anySelX and x1ok and x5ok and x10ok and x30ok and x60ok and x240ok

// Short entry — symmetric to the long: go short when the ticked TFs are
// overbought. (Gate B divergence / momentum gate are long-side only.)
entryShort = useShort and overbought and shortOk

// ---------------------------------------------------------------- orders
// Position is always flat or exactly 1 contract: we only ever enter when flat
// (pyramiding=0, qty=1), so long and short can never coexist.
flat = strategy.position_size == 0

// ATR is frozen at entry so the INITIAL stop/target stay fixed for the trade.
// The protective stop only ever moves in your favour (breakeven / trail),
// never looser — so worst-case loss is still the initial ATR stop.
var float atrEntry  = na
var float trailStop = na

// ---- entries: only when flat. Long takes precedence if both fire the same bar.
if flat and barstate.isconfirmed
    if entryLong
        atrEntry  := atrVal
        trailStop := na
        strategy.entry("Long", strategy.long, qty=qty, comment="MTF-RSI")
    else if entryShort
        atrEntry  := atrVal
        trailStop := na
        strategy.entry("Short", strategy.short, qty=qty, comment="MTF-OB")

// ---- long management: fixed target + breakeven/trailing stop.
if strategy.position_size > 0
    entryPx = strategy.position_avg_price
    tpPx    = entryPx + tpMult * atrEntry
    trailStop := na(trailStop) ? entryPx - atrMult * atrEntry : trailStop
    if useBE and high >= entryPx + beTrig * atrEntry
        trailStop := math.max(trailStop, entryPx)                 // lock breakeven
    if useTrail
        trailStop := math.max(trailStop, close - trailMult * atrEntry)
    strategy.exit("L-Bracket", from_entry="Long", stop=trailStop, limit=tpPx, comment="ATR")
    if useObExit and overbought and barstate.isconfirmed
        strategy.close("Long", comment="RSI-OB")

// ---- short management: mirror of the long side.
if strategy.position_size < 0
    entryPx = strategy.position_avg_price
    tpPx    = entryPx - tpMult * atrEntry
    trailStop := na(trailStop) ? entryPx + atrMult * atrEntry : trailStop
    if useBE and low <= entryPx - beTrig * atrEntry
        trailStop := math.min(trailStop, entryPx)                 // lock breakeven
    if useTrail
        trailStop := math.min(trailStop, close + trailMult * atrEntry)
    strategy.exit("S-Bracket", from_entry="Short", stop=trailStop, limit=tpPx, comment="ATR")
    if useObExit and gateA and barstate.isconfirmed
        strategy.close("Short", comment="RSI-OS")

// reset the protective stop whenever flat so the next trade re-initialises it
if flat
    trailStop := na

// ---------------------------------------------------------------- plotting
plotshape(entryLong and flat, title="Long entry", style=shape.triangleup,
     location=location.belowbar, color=color.new(color.teal, 0), size=size.small)
plotshape(entryShort and flat and not entryLong, title="Short entry", style=shape.triangledown,
     location=location.abovebar, color=color.new(color.maroon, 0), size=size.small)

longPos  = strategy.position_size > 0
shortPos = strategy.position_size < 0
bgcolor(longPos ? color.new(color.teal, 92) : shortPos ? color.new(color.maroon, 92) : na, title="In position")

// Live protective stop (red, follows breakeven/trail) and fixed take-profit
// (green). For a short the target is below entry.
stopLine = (longPos or shortPos) ? trailStop : na
tpLine   = longPos ? strategy.position_avg_price + tpMult * atrEntry : shortPos ? strategy.position_avg_price - tpMult * atrEntry : na
plot(stopLine, "Stop",   color=color.red,   style=plot.style_linebr, linewidth=1)
plot(tpLine,   "Target", color=color.green, style=plot.style_linebr, linewidth=1)

// Higher-timeframe trend EMA — entries are blocked against a confirmed trend.
plot(useTrend ? trendEma : na, "Trend EMA", color=color.new(color.orange, 0), linewidth=1)

// ---------------------------------------------------------------- alerts
alertcondition(entryLong and flat, "GC MTF RSI — LONG ENTRY",
     "GC MTF RSI long entry: multi-TF oversold/divergence + momentum aligned.")
alertcondition(entryShort and flat and not entryLong, "GC MTF RSI — SHORT ENTRY",
     "GC MTF RSI short entry: multi-TF overbought.")
alertcondition(strategy.position_size > 0 and overbought, "GC MTF RSI — RSI overbought exit",
     "GC MTF RSI: multi-TF RSI overbought — long take-profit exit.")

// ---------------------------------------------------------------- status table
f_yn(b) => b ? "Y" : "N"
f_cellcol(b) => b ? color.new(color.teal, 0) : color.new(color.gray, 40)

f_row(t, row, name, rsiv, th, extra) =>
    table.cell(t, 0, row, name)
    table.cell(t, 1, row, str.tostring(rsiv, "#.0"))
    table.cell(t, 2, row, f_yn(rsiv <= th), bgcolor=f_cellcol(rsiv <= th))
    table.cell(t, 3, row, extra)

var table t = table.new(position.top_right, 4, 8, border_width=1)

if showTable and barstate.islast
    table.cell(t, 0, 0, "TF",  text_color=color.white, bgcolor=color.new(color.blue, 0))
    table.cell(t, 1, 0, "RSI", text_color=color.white, bgcolor=color.new(color.blue, 0))
    table.cell(t, 2, 0, "<=th",text_color=color.white, bgcolor=color.new(color.blue, 0))
    table.cell(t, 3, 0, "div/mom", text_color=color.white, bgcolor=color.new(color.blue, 0))

    // Leading "•" marks a timeframe that is ticked for the Gate A entry.
    f_row(t, 1, (useA1   ? "•1m"  : " 1m"),  rsi1,   th1,   "")
    f_row(t, 2, (useA5   ? "•5m"  : " 5m"),  rsi5,   th5,   (div5  ? "div " : "") + (mom5  > momThr ? "m+" : "m-"))
    f_row(t, 3, (useA10  ? "•10m" : " 10m"), rsi10,  th10,  (div10 ? "div " : "") + (mom10 > momThr ? "m+" : "m-"))
    f_row(t, 4, (useA30  ? "•30m" : " 30m"), rsi30,  th30,  (div30 ? "div " : "") + (mom30 > momThr ? "m+" : "m-"))
    f_row(t, 5, (useA60  ? "•1h"  : " 1h"),  rsi60,  th60,  mom60  >= momFloor ? "m>=0" : "m<0")
    f_row(t, 6, (useA240 ? "•4h"  : " 4h"),  rsi240, th240, mom240 >= momFloor ? "m>=0" : "m<0")

    sigTxt = (entryLong and flat) ? "LONG" : (entryShort and flat) ? "SHORT" : "-"
    sigCol = (entryLong and flat) ? color.new(color.green, 0) : (entryShort and flat) ? color.new(color.maroon, 0) : color.new(color.gray, 20)
    table.cell(t, 0, 7, sigTxt, text_color=color.white, bgcolor=sigCol)
    table.cell(t, 1, 7, gateA ? "A" : "-", bgcolor=f_cellcol(gateA))
    table.cell(t, 2, 7, overbought ? "OB" : "-", bgcolor=f_cellcol(overbought))
    table.cell(t, 3, 7, momGate ? "mom" : "-", bgcolor=f_cellcol(momGate))
